#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# [AUTONOMOUS FACTORY PRE-COMMIT HOOK]
# This script physically prevents any AI Agent (or human) from committing broken code to the repository.
# The agent will receive a non-zero exit code if this fails, forcing them to fix the code before proceeding.

echo "🔒 [PRE-COMMIT GATE]: Running Monorepo Code Quality Checks..."

# 1. Typecheck the entire monorepo
echo "📝 Typechecking all packages and apps..."
pnpm turbo run typecheck --filter=...[HEAD~1]
if [ $? -ne 0 ]; then
  echo "❌ [PRE-COMMIT FAILED]: TypeScript errors detected. You MUST fix these before committing."
  exit 1
fi

# 2. Lint the entire monorepo
echo "🧹 Linting all packages and apps..."
pnpm turbo run lint --filter=...[HEAD~1]
if [ $? -ne 0 ]; then
  echo "❌ [PRE-COMMIT FAILED]: Linter errors detected. You MUST fix these before committing."
  exit 1
fi

# 3. Run unit tests on modified packages only
echo "🧪 Running unit tests on modified packages..."
pnpm turbo run test --filter=...[HEAD~1]
if [ $? -ne 0 ]; then
  echo "❌ [PRE-COMMIT FAILED]: Unit tests failed. You MUST fix the failing tests before committing."
  exit 1
fi

echo "✅ [PRE-COMMIT SUCCESS]: Code quality checks passed. Proceeding with commit."
