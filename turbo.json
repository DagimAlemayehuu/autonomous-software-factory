{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**",
                "src-tauri/target/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.py", "pyproject.toml", "uv.lock"]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.py", "pyproject.toml", "uv.lock"]
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.py", "tests/**/*.py", "tests/**/*.ts", "pyproject.toml", "uv.lock"]
        },
        "clean": {
            "cache": false
        }
    }
}