# Enterprise Monorepo Template - Environment Variable Template
# Copy this file to .env and populate with your values.
# NEVER commit .env to source control.

# --- API Keys (managed via Tauri Store at runtime, not loaded from .env in production) ---
# These are provided here only for local development / CLI testing of the Python sidecar in isolation.
GEMINI_API_KEY=
NOTION_API_KEY=

# --- Paths ---
OBSIDIAN_VAULT_PATH=

# --- Python Sidecar ---
API_HOST=127.0.0.1
API_PORT=8765
